{
  "name": "rannuan-music-player",
  "version": "1.0.0",
  "description": "A cross-platform NetEase Cloud Music player built with React Native + Expo",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "api": "npx NeteaseCloudMusicApi@latest --host 0.0.0.0",
    "dev": "concurrently \"npm run api\" \"expo start\"",
    "dev:web": "concurrently \"npm run api\" \"expo start --web\"",
    "postinstall": "node scripts/patch-zustand.js && node scripts/patch-rntp.js",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AARONWEI97/RanNuan-Music-Player.git"
  },
  "keywords": [
    "react-native",
    "expo",
    "music-player",
    "netease-cloud-music",
    "typescript"
  ],
  "author": "AARONWEI97",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AARONWEI97/RanNuan-Music-Player/issues"
  },
  "homepage": "https://github.com/AARONWEI97/RanNuan-Music-Player#readme",
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "axios": "^1.16.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-file-system": "~19.0.22",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-media-library": "~18.2.1",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-colors": "^2.6.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-track-player": "^4.1.2",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "concurrently": "^9.2.1",
    "expo-module-scripts": "^55.0.2",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "private": false
}
